@{
    var Title = ViewData["Title"] ?? "Eric Jay Catayas";
}
<head>
    <!-- Meta Tags -->
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="author" content="Laralink">
    <!-- Favicon Icon -->
    <link rel="icon" href="~/v2/img/favicon.png">
    <!-- Site Title -->
    <title>@Title</title>
    <link rel="stylesheet" href="~/v2/css/plugins/bootstrap.min.css">
    <link rel="stylesheet" href="~/v2/css/plugins/fontawesome.min.css">
    <link rel="stylesheet" href="~/v2/css/plugins/odometer-theme-default.css">
    <link rel="stylesheet" href="~/v2/css/plugins/select2.min.css">
    <link rel="stylesheet" href="~/v2/css/plugins/animate.css">
    <link rel="stylesheet" href="~/v2/css/style.css">
    @* From old  *@
    <link rel="stylesheet" href="~/css/carousel.css">
    <link rel="stylesheet" href="~/css/timeline.css">
    <link rel="stylesheet" href="~/css/owl.carousel.min.css">
    <link rel="stylesheet" href="~/css/owl.theme.default.min.css">
</head>
<main>
    @RenderBody()
</main>

<body>
    <div class="cs_preloader cs_center" style="display: none;">
        <div class="cs_preloader_in" style="display: none;"></div>
    </div>

    <!-- Start Header Section -->
    <header class="cs_site_header cs_style_1 cs_sticky_header cs_color_2 cs_gescout_sticky">
        <div class="cs_main_header">
            <div class="container">
                <div class="cs_main_header_in">
                    <div class="cs_main_header_left">
                        <a class="cs_site_branding" href="/">
                            <h1 class="cs_font_28 cs_bold"><span class="cs_gradient_text">Eric Jay</span></h1>
                        </a>
                    </div>
                    <div class="cs_main_header_center">
                        <div class="cs_nav">
                            <ul class="cs_nav_list">
                                <li> <a href="/">Home</a></li>
                                <li> <a href="/about">About</a></li>
                                <li> <a href="/work">Work</a></li>
                                <li> <a href="/projects">Projects</a></li>
                                <li> <a href="/contact">Contact</a></li>
                            </ul>
                            <span class="cs_menu_toggle"><span></span></span>
                        </div>
                    </div>
                    <div class="cs_main_header_right">
                        <span> </span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- End Header Section -->
    <!-- Start Footer -->
    <footer class="cs_footer cs_style_1 cs_filled_bg position-relative"
            style="background-image: url('@Url.Content("~/images/bg/footer_bg.svg")');">
        <div class="container">
            <div class="cs_footer_cta text-center text-lg-start py-5">
                <div class="row w-100">
                    <div class="col-lg-7">
                        <h2 class="cs_font_48 cs_gradient_text_2 cs_bold mb-2">
                            Eric Jay Catayas
                        </h2>
                        <h3 class="cs_font_28 cs_accent_color cs_semi_bold mb-4">
                            Full Stack Web Developer
                        </h3>
                    </div>
                    <!-- Navigation -->
                    <div class="col-lg-3">
                        <nav class="footer-nav d-flex flex-wrap justify-content-evenly flex-lg-column gap-1 gap-md-2 mb-4">
                            <a href="/">Home</a>
                            <a href="/about">About</a>
                            <a href="/work">Work</a>
                            <a href="/projects">Projects</a>
                            <a href="/contact">Contact</a>
                        </nav>
                    </div>

                    <div class="col-lg-2">
                        <!-- Social Links -->
                        <div class="footer-social d-flex flex-wrap justify-content-center">
                            <partial name="_SocialShare" />
                        </div>
                    </div>

                </div>
            </div>

            <!-- Copyright -->
            <div class="cs_copyright text-center py-3">
                © 2026 Eric Jay Catayas. All rights reserved.
            </div>

        </div>

    </footer>
    <!-- End Footer -->
    <!-- Script -->
    <script src="~/js/plugins.js"></script>
    <script src="~/js/owl.carousel.min.js"></script>
    <script src="~/js/email-service.js"></script>
    @* v2 *@
    <script src="~/v2/js/plugins/jquery-3.6.0.min.js"></script>
    <script src="~/v2/js/plugins/gsap.min.js"></script>
    <script src="~/v2/js/plugins/isotope.pkg.min.js"></script>
    <script src="~/v2/js/plugins/odometer.min.js"></script>
    <script src="~/v2/js/plugins/wow.min.js"></script>
    <script src="~/v2/js/main.js"></script>
    <script defer="" src="https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447" integrity="sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==" data-cf-beacon="{&quot;version&quot;:&quot;2024.11.0&quot;,&quot;token&quot;:&quot;6f756f02820545e3be40ddc6eb6154c3&quot;,&quot;r&quot;:1,&quot;server_timing&quot;:{&quot;name&quot;:{&quot;cfCacheStatus&quot;:true,&quot;cfEdge&quot;:true,&quot;cfExtPri&quot;:true,&quot;cfL4&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfSpeedBrain&quot;:true},&quot;location_startswith&quot;:null}}" crossorigin="anonymous"></script>
    <span class="cs_cursor_lg d" style="translate: none; rotate: none; scale: none; transform: translate(-50%, -50%) translate(1371px, 129px);"></span>
    <span class="cs_cursor_sm" style="translate: none; rotate: none; scale: none; transform: translate(-50%, -50%) translate(1371px, 129px);"></span>
</body>