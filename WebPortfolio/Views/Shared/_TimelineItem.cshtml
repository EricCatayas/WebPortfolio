@model WebPortfolio.ViewModels.TimelineItemVM
<div class="timeline-item @(Model.IsActive ? "active" : "")">
    <div class="timeline-dot"></div>

    <details @(Model.IsActive ? "open" : "") class="p-4">
        <summary>
            <div class="timeline-header">
                <h3>@Model.Experience.Title</h3>
                <span>@Model.Experience.Date</span>
                <a href="@Model.Experience.Company.Link" target="_blank">
                    <strong>@Model.Experience.Company.Name</strong>
                </a>
                <p class="font_16">@Model.Experience.Company.Location (@Model.Experience.Type)</p>
            </div>
        </summary>

        <div class="timeline-content">
            <div class="row">
                <div class="col-md-8">
                    <p class="font_16">@Model.Experience.Description</p>
                    <h6>Contributions</h6>
                    <ul>
                        @foreach (var contribution in Model.Experience.Contributions)
                        {
                            <li class="font_16">@contribution</li>
                        }
                    </ul>
                </div>
                <div class="col-md-4">
                    <div class="portfolio style_2 position-relative">
                        <a href="@Url.Content(Model.Experience.ImageUrl)" target="_blank" class="portfolio_thumbnail zoom">
                            <img class="zoom_in w-100" src="@Url.Content(Model.Experience.ImageUrl)" alt="">
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </details>
</div>