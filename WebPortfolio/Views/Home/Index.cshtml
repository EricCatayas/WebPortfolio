@model WebPortfolio.ViewModels.HomeVM

<!-- Start Hero Section -->
<section class="cs_hero cs_style_2 cs_filled_bg" style="background-image: url('@Url.Content("~/images/bg/hero_bg_2.svg")');">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="cs_hero_info cs_pr_20 pb-5">
                    <h4 class="cs_hero_meta cs_font_48 cs_white_blue_text_2 cs_semi_bold cs_primary_font mb-0">
                        Hi! I’m<br>
                    </h4>
                    <h1 class="cs_hero_title cs_font_92 cs_bold wow fadeInLeft" data-wow-duration="0.8s" data-wow-delay="0.2s" style="visibility: visible; animation-duration: 0.8s; animation-delay: 0.2s; animation-name: fadeInLeft;"><span class="cs_gradient_text">Eric Jay </span><span class="cs_gradient_border_text">Catayas</span></h1>
                    <h4 class="cs_hero_subtitle cs_font_36 cs_semi_bold cs_primary_font cs_accent_color_2">
                        Full Stack
                        <span class="cs_accent_color">Web Developer</span>
                    </h4>
                    <p class="cs_hero_text">
                        I’m a <span class="cs_primary_color">Full Stack Web Developer</span> focused on designing, developing, and deploying web applications. With experience building real-world platforms using modern <span class="cs_primary_color">JavaScript technologies</span>, I enjoy transforming ideas into functional products through clean code, creative problem-solving, and continuous learning.


                    </p>
                    <partial name="_SocialShare" />
                    <div class="cs_btns">
                        <a href="documents/Eric Jay Catayas Resume.pdf" target="_blank" class="cs_btn cs_style_1"><span>Resume</span></a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="cs_hero_image_box cs_filled_bg">

                    <div class="cs_imagebox_img d-none d-lg-block">
                        <img src="~/images/hero/hero_2.png" alt="heroImg">
                    </div>

                    <div class="cs_imageround_wrapper d-flex justify-content-center d-block d-lg-none">
                        <div class="cs_imageround_img">
                            <img src="~/images/hero/hero_4.png" alt="heroImg">
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<!-- End Hero Section -->
<!-- Start Projects Section -->
<section class="cs_filled_bg cs_100_bg" style="background-image: url('@Url.Content("~/images/bg/portfolio_bg2.png")');">
    <div class="cs_height_150 cs_height_lg_80"></div>
    <div class="container">
        <div class="cs_isotop cs_isotop_col_2 cs_has_gutter_80" style="position: relative; height: 1197.5px;">
            <div class="cs_grid_sizer"></div>
            <div class="cs_isotop_item" style="position: absolute; left: 0%; top: 0px;">
                <div class="cs_portfolio cs_style_2">
                    <div class="cs_section_heading cs_style_1">
                        <h2 class="cs_section_title cs_font_48 cs_semi_bold">
                            Project
                            <br><span class="cs_accent_color">Highlights</span>
                        </h2>
                    </div>
                </div>
            </div>
            @foreach (var project in Model.Projects)
            {
                <partial name="_ProjectCard2" model="project" />
            }            
            <div class="cs_isotop_item" style="position: absolute; left: 0%; top: 954.55px;">
                <div class="cs_portfolio cs_style_2 text-center cs_radius_20 overflow-hidden wow fadeInUp" data-wow-duration="0.8s" data-wow-delay="0.2s" style="visibility: hidden; animation-duration: 0.8s; animation-delay: 0.2s; animation-name: none;">
                    @{
                        ViewData["Href"] = "/projects";
                        ViewData["Text"] = "View All Projects";
                    }
                    <partial name="_NavigationLink" view-data="ViewData" />
                </div>
            </div>
        </div>
    </div>
    <div class="cs_height_150 cs_height_lg_80"></div>
</section>
<!-- End Projects Section -->
<!-- Start Work Experience Carousel-->
<section id="work" class="work text-center">
    <div class="container">
        <div class="cs_section_heading cs_style_1 text-center">
            <h2 class="cs_section_title cs_font_48 cs_semi_bold">
                Work <span class="cs_accent_color">Experience</span>
            </h2>
            <div class="cs_height_25 cs_height_lg_10"></div>
            <p>I began my professional journey as a <span class="cs_primary_color">Computer Science</span> undergraduate, gaining <span class="cs_primary_color">real work experience</span> through internships and development roles focused on full stack web development.</p>
            <div class="cs_height_70 cs_height_lg_40"></div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="featured-carousel owl-carousel">
                    @foreach (var work in Model.WorkExperiences)
                    {
                        @await Html.PartialAsync("_CarouselItem", work)
                    }
                </div>
            </div>
        </div>
    </div>
    @{
        ViewData["Href"] = "/work";
        ViewData["Text"] = "View Work History";
    }
    <div class="cs_height_25 cs_height_lg_10"></div>
    <partial name="_NavigationLink" view-data="ViewData" />
    <div class="cs_height_40 cs_height_lg_30"></div>
</section>
<!-- End Work Experience Carousel-->
<!-- Start What I do Section -->
<section class="cs_funfact_2_wrap py-5">
    <div class="cs_about_bg cs_filled_bg" style="background-image: url('@Url.Content("~/images/bg/about_bg_1.svg")');"></div>
    <div class="cs_funfact_content container">
        <div class="row">
            <div class="col-lg-6">
                <div class="cs_pr_50">
                    <div class="cs_section_heading cs_style_1">
                        <h2 class="cs_section_title cs_font_48 cs_gradient_text_2 cs_semi_bold">
                            What I do
                        </h2>
                    </div>
                    <div class="cs_height_40 cs_height_lg_30"></div>
                    <p class="cs_white_color m-0">
                        I'm a Full Stack Web Developer with hands-on experience in designing, developing, and deploying web applications. I was formerly a visual artist, but got hooked to web development because of the combination of architectural and design creativity. If you have any questions or would like to discuss potential opportunities, please feel free to reach out.
                    </p>
                    <div class="cs_height_25 cs_height_lg_20"></div>
                    <div class="d-flex flex-wrap gap-2">
                        @{
                            ViewData["Href"] = "/about";
                            ViewData["Text"] = "About Me";
                        }
                        <partial name="_NavigationLink" view-data="ViewData" />
                    </div>
                </div>
                <div class="cs_height_lg_30"></div>
            </div>
            <div class="col-lg-6">
                <div class="cs_pl_70">
                    <div class="cs_iconbox cs_style_2 cs_radius_20 cs_transition_4">
                        <div class="cs_iconbox_in">
                            <div class="cs_iconbox_icon cs_center">
                                <img src="~/images/icon/about_icon_1.svg" alt="Icon">
                            </div>
                            <div class="cs_iconbox_info position-relative w-100">
                                <h3 class="cs_iconbox_title cs_font_28 cs_medium m-0">UI/UX Implementation</h3>
                                <p class="cs_iconbox_text">Creating responsive and user-friendly experiences.</p>
                            </div>
                        </div>
                    </div>
                    <div class="cs_iconbox cs_style_2 cs_radius_20 cs_transition_4">
                        <div class="cs_iconbox_in">
                            <div class="cs_iconbox_icon cs_center">
                                <img src="~/images/icon/about_icon_2.svg" alt="Icon">
                            </div>
                            <div class="cs_iconbox_info position-relative w-100">
                                <h3 class="cs_iconbox_title cs_font_28 cs_medium m-0">Full Stack Development</h3>
                                <p class="cs_iconbox_text">Building complete web applications from frontend interfaces to backend services.</p>
                            </div>
                        </div>
                    </div>
                    <div class="cs_iconbox cs_style_2 cs_radius_20 cs_transition_4">
                        <div class="cs_iconbox_in">
                            <div class="cs_iconbox_icon cs_center">
                                <img src="~/images/icon/about_icon_3.svg" alt="Icon">
                            </div>
                            <div class="cs_iconbox_info position-relative w-100">
                                <h3 class="cs_iconbox_title cs_font_28 cs_medium m-0">Database & API Development</h3>
                                <p class="cs_iconbox_text">Designing efficient data structures and backend systems.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Start What I do Section -->
<!-- Start Skills Section -->
@await Html.PartialAsync("_SkillsSection")
<!-- End Skills Section -->
<!--Start Contact Section-->
@{
    ViewData["Header"] = "Want to reach out?";
    ViewData["Subheader"] = "Please use the form below, or send an email to catayasericjay@gmail.com";
}
@await Html.PartialAsync("_ContactForm", ViewData)
<!--End Contact Section-->